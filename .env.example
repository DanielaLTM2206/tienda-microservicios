# =============================================================================
# Variables de entorno del sistema (valores de desarrollo por defecto).
# Docker Compose ya define estos valores por servicio; este archivo documenta
# la configuracion esperada para correr los servicios FUERA de Docker
# (npm run start:<servicio>) o para sobreescribirla.
# Copiar a .env y ajustar: cp .env.example .env
# =============================================================================

# --- Gateway ---
PORT=3000
SVC_PEDIDOS_HOST=localhost
SVC_PEDIDOS_PORT=3001

# --- svc-pedidos ---
TCP_PORT=3001
SVC_PRODUCTOS_HOST=localhost
SVC_PRODUCTOS_PORT=3002
GRPC_PRODUCTOS_URL=localhost:5000

# --- svc-productos ---
# TCP_PORT=3002
GRPC_PORT=5000

# --- PostgreSQL (una base de datos por microservicio) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=app
DB_PASS=app
# svc-pedidos usa pedidos_db; svc-productos usa productos_db (ver scripts/init-db.sql)
DB_NAME=pedidos_db

# --- Redis (camino asincrono Avance 1) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- RabbitMQ (segundo transporte asincrono, Avance 2) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
